{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*\\.(?:html|css|js))",
      "dest": "/$1"
    },
    {
      "src": "/details",
      "dest": "/details.html"
    },
    {
      "src": "/home",
      "dest": "/home.html"
    },
    {
      "src": "/next-week",
      "dest": "/next-week.html"
    },
    {
      "src": "/workout",
      "dest": "/workout.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}